{
  "name": "opsdesk-ai",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit && pnpm test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "seed": "tsx scripts/seed-demo.ts",
    "worker": "tsx scripts/worker.ts",
    "local:up": "docker compose --profile postgres up -d",
    "local:events": "docker compose --profile postgres --profile events up -d",
    "local:full": "docker compose --profile postgres --profile events --profile search --profile graph up -d",
    "local:seed": "tsx scripts/seed-demo.ts --database",
    "local:worker": "tsx scripts/worker.ts",
    "local:down": "docker compose --profile postgres --profile events --profile search --profile graph down",
    "local:reset": "docker compose --profile postgres --profile events --profile search --profile graph down -v"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.52",
    "@react-router/node": "^7.15.1",
    "@react-router/serve": "^7.15.1",
    "ai": "^5.0.91",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.0",
    "framer-motion": "^12.23.26",
    "isbot": "^5.1.32",
    "lucide-react": "^0.554.0",
    "pg": "^8.16.3",
    "pg-boss": "^10.4.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.15.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@netlify/vite-plugin-react-router": "^3.1.1",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.2",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "drizzle-kit": "^0.31.8",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7"
  }
}
